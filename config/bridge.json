{
  "workers": {
    "openclaw": {
      "enabled": true,
      "max_concurrent": 5,
      "description": "OpenClaw操作任务处理器"
    },
    "ai": {
      "enabled": true,
      "max_concurrent": 3,
      "description": "AI模型调用任务处理器"
    },
    "script": {
      "enabled": true,
      "max_concurrent": 2,
      "description": "本地脚本执行任务处理器"
    },
    "webhook": {
      "enabled": true,
      "max_concurrent": 10,
      "description": "Webhook调用任务处理器"
